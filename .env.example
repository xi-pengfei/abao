# 拷贝为 .env 并填入真实密钥。.env 不应进入版本控制。

# 主力 LLM（DeepSeek）
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx

# 备选：Qwen / 阿里通义千问
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxx

# 备选：OpenAI（如果切到 openai 提供商）
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx

# 数据目录（默认项目内 data/，可改为绝对路径）
SHADOW_DATA_DIR=./data

# 手机/PWA HTTP API 访问令牌。网页设置里的 Access Token 填这个值本身，不要加 Bearer。
ABAO_OWNER_TOKEN=change-me-to-a-long-random-token

# 当前实例的显示名和短标识。多实例部署时建议在各自 .env 里改这里，不要改 config/providers.yaml。
ABAO_DISPLAY_NAME=阿宝
ABAO_APP_SLUG=abao
